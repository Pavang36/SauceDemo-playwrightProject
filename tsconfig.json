{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "sourceMap": true
  },
  "include": ["tests/**/*.ts", "fixtures/**/*.ts", "pages/**/*.ts"]
}